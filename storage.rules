rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /voiceMessages/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
